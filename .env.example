LEGAL_CORPUS_SOURCES=indiacode,egazette
LEGAL_CORPUS_OUTPUT_DIR=.
LEGAL_CORPUS_LOG_LEVEL=INFO

LEGAL_CORPUS_REQUEST_TIMEOUT_SECONDS=30
LEGAL_CORPUS_POLITE_DELAY_SECONDS=1.25
LEGAL_CORPUS_RETRY_ATTEMPTS=3
LEGAL_CORPUS_RETRY_BACKOFF_SECONDS=1.5

LEGAL_CORPUS_BROWSER_NAME=chromium
LEGAL_CORPUS_BROWSER_CHANNEL=msedge
LEGAL_CORPUS_BROWSER_HEADLESS=true
LEGAL_CORPUS_BROWSER_TIMEOUT_MS=45000
LEGAL_CORPUS_DOWNLOAD_TIMEOUT_MS=8000

LEGAL_CORPUS_INDIACODE_BROWSE_TYPE=shorttitle
LEGAL_CORPUS_INDIACODE_RESULTS_PER_PAGE=100
LEGAL_CORPUS_INDIACODE_MAX_BROWSE_PAGES=12

LEGAL_CORPUS_EGAZETTE_MAX_LISTING_PAGES=10
LEGAL_CORPUS_EGAZETTE_MAX_FOLLOW_LINKS_PER_ENTRYPOINT=8
LEGAL_CORPUS_EGAZETTE_CAPTURE_DOWNLOAD_URLS=true
LEGAL_CORPUS_EGAZETTE_ENTRYPOINTS=
LEGAL_CORPUS_EGAZETTE_MAX_ROWS_PER_PAGE=0
